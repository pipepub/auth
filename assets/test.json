{
    "_title": "PipePub TEST MODE - Local Mock OAuth",
    "_file": "/assets/test.json",
    "_version": "1.0.0",
    "public_key": "pipepub_test_mock_key",
    "services": {
        "MockOAuth": {
            "name": "Local Mock OAuth Provider",
            "secret_name": "MOCK_TOKEN",
            "authorize_url": "mock/index.html",
            "token_url": "https://httpbin.org/post",
            "scope": "read write",
            "response_type": "code",
            "supports_refresh": true,
            "access_token_lifetime_hours": 1,
            "note": "TEST MODE ONLY - Self-contained mock OAuth provider"
        },
        "MockOAuthPKCE": {
            "name": "Local Mock OAuth (PKCE Required)",
            "secret_name": "MOCK_PKCE_TOKEN",
            "authorize_url": "mock/index.html",
            "token_url": "https://httpbin.org/post",
            "scope": "read write pkce",
            "response_type": "code",
            "supports_refresh": true,
            "requires_pkce": true,
            "access_token_lifetime_hours": 1,
            "note": "TEST MODE - Requires code_challenge parameter"
        },
        "MockOAuthNoRefresh": {
            "name": "Local Mock OAuth (No Refresh)",
            "secret_name": "MOCK_NOREFRESH_TOKEN",
            "authorize_url": "mock/index.html",
            "token_url": "https://httpbin.org/post",
            "scope": "read write norefresh",
            "response_type": "code",
            "supports_refresh": false,
            "access_token_lifetime_days": 60,
            "note": "TEST MODE - Simulates LinkedIn behavior"
        }
    }
}